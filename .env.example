# Copy to .env and fill in as each feature comes online. Never commit .env.

# ── Database (Supabase Postgres) — needed for the data layer ──
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# ── Supabase (file storage for uploaded PDFs) ──
SUPABASE_URL=""
SUPABASE_SERVICE_KEY=""

# ── AI finish-schedule reading ──
ANTHROPIC_API_KEY=""

# ── Google Sheets sync (service account JSON, single line) ──
GOOGLE_SERVICE_ACCOUNT_JSON=""
# The Drive file id of the master Sheet template the app copies per project:
SHEET_TEMPLATE_ID=""
