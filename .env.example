# Copy to .env and fill in as each feature comes online. Never commit .env.

# ── Database (Supabase Postgres) — needed for the data layer ──
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# ── Supabase (file storage for uploaded PDFs) ──
SUPABASE_URL=""
SUPABASE_SERVICE_KEY=""
SUPABASE_ANON_KEY=""
# Browser uploads PDFs straight to storage (bypasses Vercel's ~4.5MB serverless body limit). These are
# the same URL + anon key as above, exposed to the client (anon key is public by design).
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# ── AI finish-schedule reading ──
ANTHROPIC_API_KEY=""

# ── Google Sheets template (service account, for building the master template) ──
SHEET_TEMPLATE_ID=""

# ── Google OAuth (user connects their Google → app creates a Sheet per bid) ──
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT=""   # <app-url>/api/auth/google/callback
APP_URL=""                 # the app's base URL (Codespaces forwarded URL in dev)

# ── SAM.gov (federal opportunity / plan fetch) ──
SAM_API_KEY=""             # get one at sam.gov → Account Details → API Key
                           # comma-separate several here (or use SAM_API_KEYS) to rotate past the
                           # per-key daily search quota during a big sam:fetch pull
SAM_API_KEYS=""            # optional extra keys, comma-separated
