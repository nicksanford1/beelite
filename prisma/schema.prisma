// Beelite — database schema. Mirrors the locked fields in claude/sheet-template.md.
// The DB stores INPUTS + review state; the Google Sheet computes the bid (no totals here).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Company / reusable catalog ───────────────────────────────
model Company {
  id       String              @id @default(cuid())
  name     String
  finishes FinishLibraryItem[]
  rates    RateCatalogEntry[]
  scopeTpl ScopeTemplateItem[]
  projects Project[]
}

model FinishLibraryItem {
  id          String            @id @default(cuid())
  companyId   String
  company     Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  code        String // "LVT-1"
  type        String
  description String
  unit        String // SF | LF | EA | SY
  category    String // floor | base | transition | wall | other
  rate        RateCatalogEntry?

  @@unique([companyId, code])
}

// Company-standard rate (the "ceiling") that seeds new bids. v5: install is always a per-unit sub
// rate; material is either Elite-furnished or owner-furnished (see v5-math-contract.md).
model RateCatalogEntry {
  id               String            @id @default(cuid())
  companyId        String
  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  finishId         String            @unique
  finish           FinishLibraryItem @relation(fields: [finishId], references: [id], onDelete: Cascade)
  materialUnitCost Float // $/unit Elite pays the supplier
  installRate      Float // $/unit Elite pays the sub
  wastePct         Float
  cartonSize       Float?
  materialSource   String            @default("elite_furnishes") // elite_furnishes | owner_furnishes
}

model ScopeTemplateItem {
  id          String  @id @default(cuid())
  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  label       String
  defaultMode String // included | excluded | pending
}

// ── Project / per bid ────────────────────────────────────────
model Project {
  id                String             @id @default(cuid())
  companyId         String
  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name              String
  bidDate           DateTime?
  gc                String? // GC / Customer
  location          String?
  projectType       String? // e.g. "Office TI", "Restaurant", "Worship / Commercial"
  architect         String?
  estimator         String?
  leadSource        String? // Permit, GC email, referral, …
  internalBidNum    String?
  // Structured cover-read metadata (from extractProjectInfo) — preserved, not stuffed into notes.
  owner             String?
  squareFeet        String? // kept as text: plans say "12,456 SF" / "approx 22,600" — normalize later
  projectNumber     String?
  issueDate         String? // as printed on the title block; not a real Date yet
  notes             String?
  status            String             @default("draft") // label only
  sheetId           String? // Google Sheet id (after template copy)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @default(now()) @updatedAt
  documents         Document[]
  finishes          ProjectFinish[]
  finishAssignments FinishAssignment[]
  scopeItems        ProjectScopeItem[]
  takeoff           TakeoffLine[]
  settings          EstimateSettings?
}

model Document {
  id               String      @id @default(cuid())
  projectId        String
  project          Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fileUrl          String
  originalFilename String? // the user's upload name (fileUrl is a storage path — don't parse it)
  createdAt        DateTime    @default(now())
  pages            PlanSheet[]
}

model PlanSheet {
  id                 String      @id @default(cuid())
  documentId         String
  document           Document    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  pageNumber         Int
  sheetNumber        String? // "A601"
  sheetTitle         String? // "FINISH SCHEDULE"
  sheetType          String      @default("untagged") // human-confirmed: untagged | finish_schedule | finish_plan | floor_plan | specs | ignore
  suggestedSheetType String? // scanner's guess (same vocabulary)
  scanScore          Float? // 0..1 finish-schedule likelihood
  scanSignals        Json? // per-page signal breakdown (debuggable)
  extraction         Extraction?

  @@unique([documentId, pageNumber])
}

model ProjectFinish {
  id               String             @id @default(cuid())
  projectId        String
  project          Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  code             String
  type             String
  description      String
  unit             String
  category         String
  application      String             @default("other") // floor | base | transition | stair | accessory | other
  inScope          Boolean            @default(true)
  // v5 rates (see claude/v5-math-contract.md). Install is always a per-unit sub rate.
  materialUnitCost Float              @default(0) // $/unit Elite pays the supplier
  installRate      Float              @default(0) // $/unit Elite pays the sub
  wastePct         Float              @default(0)
  cartonSize       Float?
  materialSource   String             @default("elite_furnishes") // elite_furnishes | owner_furnishes
  rateStatus       String             @default("needs_rate") // seeded | manual | needs_rate (provenance; effective status computed)
  libraryItemId    String? // provenance: which FinishLibraryItem seeded this
  assignments      FinishAssignment[]

  @@unique([projectId, code]) // Sheet assumes unique finish codes per project
}

// A finish is priced once; assignments record every room/area where the schedule uses it.
model FinishAssignment {
  id          String        @id @default(cuid())
  projectId   String
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  finishId    String
  finish      ProjectFinish @relation(fields: [finishId], references: [id], onDelete: Cascade)
  level       String?
  roomNumber  String?
  roomName    String?
  sourceSheet String?
  sourceText  String?
  confidence  Float         @default(0)
  needsReview Boolean       @default(false)
  notes       String?

  @@index([projectId])
  @@index([finishId])
}

model ProjectScopeItem {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  label     String
  mode      String // included | excluded | pending
  allowance Float?
}

model TakeoffLine {
  id         String  @id @default(cuid())
  projectId  String
  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sheet      String?
  area       String
  finishCode String
  qty        Float
  unit       String
  source     String  @default("manual") // manual | ai
  status     String  @default("draft") // draft | needs_review | approved | excluded
}

model EstimateSettings {
  id                String  @id @default(cuid())
  projectId         String  @unique
  project           Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  profitPctMode     String  @default("margin") // markup | margin — the lens the owner enters
  materialProfitPct Float // profit % on material (markup-on-cost or margin-on-price per mode)
  installProfitPct  Float // profit % on install
  taxPct            Float?
  taxMode           String  @default("total_sell_plus_freight") // material_cost_only | material_sell_only | total_sell_plus_freight
  freight           Float?
}

// Google account the app uses to create a Sheet per bid (OAuth). Single connection for now.
model GoogleConnection {
  id           String    @id @default(cuid())
  email        String?
  refreshToken String
  accessToken  String?
  expiry       DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// ── Correction log (the training/eval asset — build day 1) ───
model Extraction {
  id          String    @id @default(cuid())
  planSheetId String    @unique
  planSheet   PlanSheet @relation(fields: [planSheetId], references: [id], onDelete: Cascade)
  model       String // "claude-sonnet-4-6"
  rawOutput   Json // what the model returned
  corrected   Json? // what the human confirmed/fixed
  confidence  Json
  createdAt   DateTime  @default(now())
}

// ── External lead source: City of New Orleans permits ────────
// Raw ingest of the "Permits - BLDS" open dataset (data.nola.gov, id 72f9-bi28). Every row has a
// `link` to the OneStop permit portal where plans/documents may be attached. We store the permit
// rows here; turning a permit into a Project/plans corpus is a separate, later step. Populated by
// scripts/nola-fetch.ts. Field names mirror the BLDS spec (snake → camel).
model NolaPermit {
  id                    String    @id @default(cuid())
  permitNum             String    @unique // BLDS PermitNum, e.g. "24-11051-EVAC" — natural key
  description           String?
  // Dates
  appliedDate           DateTime?
  issueDate             DateTime?
  completeDate          DateTime?
  statusDate            DateTime?
  expiresDate           DateTime?
  coIssuedDate          DateTime?
  // Status
  statusCurrent         String?
  statusCurrentMapped   String?
  // Address
  originalAddress1      String?
  originalCity          String?
  originalState         String?
  originalZip           String?
  // Classification (mapped = BLDS-normalized vocabulary; workClassMapped "New" = new construction)
  permitClass           String?
  permitClassMapped     String?
  workClass             String?
  workClassMapped       String?
  permitType            String?
  permitTypeDesc        String?
  permitTypeMapped      String?
  // Project
  totalSqFt             Float?
  estProjectCost        Float?
  pin                   String?
  fee                   Float?
  // Contractor
  contractorCompanyName String?
  contractorTrade       String?
  contractorTradeMapped String?
  contractorLicNum      String?
  contractorStateLic    String?
  publisher             String?
  // Location + portal link
  latitude              Float?
  longitude             Float?
  link                  String? // OneStop portal redirect URL (plans/documents live behind this)
  // Lead triage (manual review of whether the portal link has usable plans)
  leadStatus            String    @default("new") // new (untriaged) | saved (good, scrape later) | dismissed (hide)
  leadNote              String?
  leadUpdatedAt         DateTime?
  // Ingest bookkeeping
  fetchedAt             DateTime  @default(now())

  @@index([workClassMapped])
  @@index([permitTypeMapped])
  @@index([issueDate])
  @@index([leadStatus])
  // The /permits default view filters permitType (flooring codes) and sorts by issueDate desc.
  // Composite index so that filter + sort + count don't scan the whole 456k-row table.
  @@index([permitType, issueDate])
  @@index([estProjectCost])
}
